---
import Layout from '../layouts/Layout.astro';

const experience = [
  {
    label: 'Currently',
    roles: [
      {
        company: 'Rosenthaler',
        url: 'https://rosenthaler.co',
        role: 'Founder',
        period: '2025–Now',
        description: 'Engineering studio in Berlin.',
        clients: [
          {
            name: 'HORSCH Maschinen',
            period: '2024–Now',
            description:
              'Custom software across their digital landscape — from myField and HORSCH Report to AI tools for weed detection, voice translation, and spare-parts forecasting. Plus technology planning and training on modern frontend development.',
          },
          {
            name: 'Innomarks',
            period: '2024–Now',
            description: 'Building the Uncovio frontend.',
          },
          {
            name: 'Almanach',
            period: '2024–2026',
            description: 'Learning platform at almanach.app — built end to end.',
          },
        ],
      },
      {
        company: 'Armbrüster Consulting',
        role: 'Freelance Developer',
        period: '2018–Now',
        description:
          'E-commerce shops, custom web applications, and shop plugins that sync data from multiple platforms into a SaaS product for automated email retargeting.',
      },
      {
        company: 'People Branding Company',
        role: 'Freelance Developer',
        period: '2025–Now',
        description: 'Supporting the continued development of Storytide, their web app.',
      },
      {
        company: 'KiezAbschnitt',
        role: 'Freelance',
        period: '2025–Now',
        description: 'Running their ad campaigns and maintaining their website.',
      },
    ],
  },
  {
    label: 'Previously',
    roles: [
      {
        company: 'Patrick & Friends',
        role: 'Freelance Developer',
        period: '2025',
        description:
          'Continued development of an online shop for a large educational institution.',
      },
      {
        company: 'smart',
        role: 'Freelance Designer',
        period: '2025',
        description: 'Contributed to the redesign of a web platform for the automotive brand.',
      },
      {
        company: 'Coffi',
        role: 'Freelance Developer',
        period: '2024',
        description: 'Full-stack development for a specialty coffee platform.',
      },
      {
        company: 'Tom Tailor',
        role: 'Freelance Developer',
        period: '2021–2022',
        description:
          'Part of the e-commerce relaunch team: the shop was rebuilt from the ground up, headless, in Next.js.',
      },
      {
        company: 'Segler Förderanlagen',
        role: 'Freelance Developer',
        period: '2019–2022',
        description:
          "Concepts, infrastructure planning, and feature development for iOS enterprise apps. Won the 'Zukunftsfest' award.",
      },
      {
        company: 'Horváth & Partners',
        role: 'Freelance Designer',
        period: '2020',
        description: 'Designed the landing page for a new digital product.',
      },
    ],
  },
];
---

<Layout title="Maximilian Gravemeyer — Founder of Rosenthaler">
  <h1>Maximilian Gravemeyer</h1>
  <p class="muted">Founder of Rosenthaler &middot; Berlin</p>

  <a class="studio" href="https://rosenthaler.co" rel="noopener">
    {/* The Rosenthaler quatrefoil: lobes on the axes, outlined diamond core
        in the same color as the outline (never rotate, never color the core). */}
    <svg viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="5" aria-hidden="true">
      <path d="M36 36 A24 24 0 0 1 84 36 A24 24 0 0 1 84 84 A24 24 0 0 1 36 84 A24 24 0 0 1 36 36 Z"></path>
      <path stroke-width="4" d="M60 43 L77 60 L60 77 L43 60 Z"></path>
    </svg>
    <span>
      <strong>Rosenthaler</strong>
      <small>We design, build, and run digital products for established companies.</small>
    </span>
    <span class="arrow" aria-hidden="true">&rarr;</span>
  </a>

  <p>
    Rosenthaler is where my work happens. Behind it are 8+ years of shipping across
    e-commerce, SaaS, and industrial systems.
  </p>

  <section class="experience">
    {
      experience.map((group) => (
        <div class="group">
          <h2>{group.label}</h2>
          {group.roles.map((r) => (
            <article>
              <div class="head">
                <strong>
                  {r.url ? <a href={r.url} rel="noopener">{r.company}</a> : r.company}
                </strong>
                <span class="role">{r.role}</span>
                <span class="period">{r.period}</span>
              </div>
              {r.description && <p class="desc">{r.description}</p>}
              {r.clients && (
                <div class="clients-list">
                  {r.clients.map((c) => (
                    <div class="client">
                      <div class="head">
                        <strong>{c.name}</strong>
                        <span class="period">{c.period}</span>
                      </div>
                      <p class="desc">{c.description}</p>
                    </div>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      ))
    }
  </section>

  <p class="routing">
    Project inquiries run through the studio &mdash; everything else, just email me.
  </p>

  <ul class="links">
    <li><a href="mailto:maximilian@gravemeyer.com">maximilian@gravemeyer.com</a></li>
    <li><a href="https://www.linkedin.com/in/mgravemeyer/" rel="noopener">LinkedIn</a></li>
    <li><a href="https://github.com/mgravemeyer" rel="noopener">GitHub</a></li>
  </ul>

  <p class="offhours">German and English. Off hours: reading, music, wedding photography.</p>
</Layout>

<style>
  .muted {
    color: #666;
    margin-top: 0.25rem;
  }
  p {
    margin-top: 1.5rem;
    max-width: 55ch;
  }
  .studio {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 2.5rem;
    padding: 1rem 1.25rem;
    border: 1px solid #e5e5e5;
    border-radius: 0.75rem;
    text-decoration: none;
    transition: border-color 150ms ease;
  }
  .studio:hover {
    border-color: #1a1a1a;
  }
  .studio svg {
    width: 2.25rem;
    height: 2.25rem;
    flex-shrink: 0;
  }
  .studio strong {
    display: block;
    font-weight: 650;
  }
  .studio small {
    display: block;
    color: #666;
    line-height: 1.45;
  }
  .studio .arrow {
    margin-left: auto;
    color: #999;
    transition: transform 150ms ease;
  }
  .studio:hover .arrow {
    transform: translateX(2px);
    color: #1a1a1a;
  }
  .experience {
    margin-top: 3rem;
  }
  .experience h2 {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #999;
    margin: 3.5rem 0 0.5rem;
  }
  .experience .group:first-child h2 {
    margin-top: 0;
  }
  .experience article {
    padding: 1rem 0;
    border-bottom: 1px solid #f0f0f0;
  }
  .experience article:last-child {
    border-bottom: none;
  }
  .experience .head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6rem;
  }
  .experience .head strong {
    font-weight: 650;
  }
  .experience .head a {
    text-decoration: none;
  }
  .experience .head a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .experience .role {
    color: #666;
    font-size: 0.9rem;
  }
  .experience .period {
    margin-left: auto;
    color: #999;
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
  }
  .experience .desc {
    margin-top: 0.35rem;
    color: #666;
    font-size: 0.95rem;
    max-width: 60ch;
  }
  .clients-list {
    margin-top: 1rem;
    padding-left: 1.25rem;
    border-left: 1px solid #e5e5e5;
  }
  .clients-list .client {
    padding: 0.6rem 0;
  }
  .clients-list strong {
    font-weight: 600;
    font-size: 0.95rem;
  }
  .routing {
    margin-top: 3rem;
  }
  .offhours {
    margin-top: 2rem;
    font-size: 0.85rem;
    color: #999;
  }
  .links {
    list-style: none;
    padding: 0;
    margin-top: 2.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    font-size: 0.95rem;
  }
</style>
